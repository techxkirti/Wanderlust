<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2 text-center">
        <h3>Account Settings</h3>
        <p class="text-muted">Once you delete your account, there is no going back. Please be certain.</p>
        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
            Delete My Account Permanently
        </button>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Permanent Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form action="/delete-account?_method=DELETE" method="POST" class="needs-validation" novalidate>
                <div class="modal-body">
                    <p class="fw-bold text-danger">WARNING: This will delete all your listings, reviews, and uploaded images.</p>
                    <p>Please enter your credentials to confirm:</p>
                    
                    <div class="mb-3 text-start">
                        <label for="username" class="form-label">Username</label>
                        <input name="username" id="username" type="text" class="form-control" required>
                    </div>
                    
                    <div class="mb-3 text-start">
                        <label for="password" class="form-label">Password</label>
                        <input name="password" id="password" type="password" class="form-control" required>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Permanently Delete Account</button>
                </div>
            </form>
        </div>
    </div>
</div>
